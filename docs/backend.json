
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stored user profile information including personality traits and preferences.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "integer" },
        "city": { "type": "string" },
        "bio": { "type": "string" },
        "profileImage": { "type": "string", "description": "Data URI of the profile picture" },
        "interests": { "type": "array", "items": { "type": "string" } },
        "customPersonalityTraits": { "type": "array", "items": { "type": "string" } },
        "personalityTraits": {
          "type": "object",
          "properties": {
            "introvertExtrovert": { "type": "number" },
            "creativeAnalytical": { "type": "number" },
            "plannerSpontaneous": { "type": "number" },
            "logicalEmotional": { "type": "number" },
            "adventurousCareful": { "type": "number" }
          }
        },
        "musicProfile": {
          "type": "object",
          "properties": {
            "genres": { "type": "array", "items": { "type": "string" } },
            "favoriteArtists": { "type": "array", "items": { "type": "string" } }
          }
        },
        "onboarded": { "type": "boolean" },
        "soulVector": { "type": "string" },
        "semanticExplanation": { "type": "string" }
      },
      "required": ["name", "onboarded"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Records likes, passes, or saves between users.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "pass", "save"] },
        "userId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat room.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/UserProfile",
      "description": "Main user document"
    },
    "/interactions": {
      "schema": "#/backend/entities/Interaction",
      "description": "Global interactions collection"
    },
    "/chat_messages_{chatId}": {
      "schema": "#/backend/entities/ChatMessage",
      "description": "Messages for a specific chat ID"
    }
  }
}
